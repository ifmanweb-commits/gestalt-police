# Токен VK бота (групповой токен для модерации, команд, вопросов)
VK_TOKEN=your_group_bot_token_here

# Пользовательский токен VK (только для публикации постов от имени сообщества)
USER_TOKEN=your_user_token_here

# ID суперпользователя (администратора бота)
SUPERUSER_ID=0

# ID чата экспертов (куда отправляются вопросы)
EXPERTS_CHAT_ID=0

# ID группы для публикации постов на стене
GROUP_ID=0
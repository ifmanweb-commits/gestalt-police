# Токен VK бота (групповой токен для модерации, команд, вопросов)
VK_TOKEN=your_group_bot_token_here

# ID суперпользователя (администратора бота)
SUPERUSER_ID=0

# ID чата экспертов (куда отправляются вопросы)
EXPERTS_CHAT_ID=0

# ID группы для публикации постов на стене
GROUP_ID=0

# Примечание: Пользовательский токен (user_access_token) теперь хранится в tokens.json
# Файл tokens.json создаётся автоматически при первом запуске
# Для OAuth 2.1 с refresh_token создайте tokens.json со структурой:
# {
#   "user_access_token": "...",
#   "user_refresh_token": "...",
#   "client_id": 54497712,
#   "redirect_uri": "https://oauth.vk.com/blank.html"
# }
